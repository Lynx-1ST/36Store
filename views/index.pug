extends layouts/default.pug
include mixins/box-head.pug

block main
    //- 1. PHẦN CHÀO MỪNG (Code cũ của bạn)
    +box-head("Trang Chủ", "Chào mừng bạn đến với hệ thống quản lý sản phẩm!")

    if message
        div.alert.alert-success
            h5 Thông điệp từ Server:
            p.mb-0 #{message}

    div.mt-4.mb-5.text-center
        p.lead Khám phá ngay các mặt hàng mới nhất của chúng tôi với giá cực sốc.
        a.btn.btn-primary.btn-lg(href="/products") 🎁 Xem toàn bộ sản phẩm

    hr.my-5

    //- 2. PHẦN TRƯNG BÀY SẢN PHẨM (Mới thêm)
    h2.text-center.mb-4.text-danger 🔥 Sản phẩm nổi bật 🔥

    div.row
        //- Kiểm tra nếu có biến products được truyền ra từ controller
        if products && products.length > 0
            each item in products
                div.col-md-3.col-sm-6.mb-4
                    div.card.h-100.shadow-sm.border-0.bg-light
                        img.card-img-top.rounded-top(
                            src=item.thumbnail || 'https://via.placeholder.com/300x300' 
                            alt=item.title 
                            style="height: 200px; object-fit: cover;"
                        )
                        div.card-body.d-flex.flex-column
                            h5.card-title.text-truncate(title=item.title) #{item.title}
                            p.card-text.text-danger.fw-bold #{item.price ? item.price.toLocaleString('vi-VN') : 0}$

                            div.mt-auto
                                a.btn.btn-outline-primary.w-100.mb-2(href=`/products/detail/${item._id}`) 👀 Xem chi tiết
                                button.btn.btn-success.w-100 🛒 Thêm vào giỏ
        else
            div.col-12
                div.alert.alert-secondary.text-center Đang cập nhật sản phẩm mới...