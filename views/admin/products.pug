extends ./admin.pug

block main
    h1 📦 Danh sách Sản phẩm
    hr
    div.mb-3.text-end
        a.btn.btn-success(href="/admin/products/create") + Thêm mới sản phẩm

    //- Bảng hiển thị dữ liệu
    table.table.table-hover.table-bordered.align-middle
        thead.table-dark
            tr
                th STT
                th Hình ảnh
                th Tên sản phẩm
                th Giá
                th Hành động
        tbody
            if products.length > 0
                //- Vòng lặp in ra từng sản phẩm
                each item, index in products
                    tr
                        td #{index + 1}
                        td
                            img(src=item.thumbnail || 'https://via.placeholder.com/80' alt=item.title width="80" class="rounded")
                        td.fw-bold #{item.title}
                        td.text-danger.fw-bold #{item.price ? item.price.toLocaleString('vi-VN') : 0}$
                        td
                            //- Sửa và Xóa
                            a.btn.btn-warning.btn-sm.me-2(href=`/admin/products/edit/${item._id}`) ✏️ Sửa
                            form(action=`/admin/products/delete/${item._id}` method="POST" style="display:inline-block;")
                                button.btn.btn-danger.btn-sm(
                                    type="submit"
                                    onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?');" 
                                ) 🗑️ Xóa
            else
                tr
                    td(colspan="5" class="text-center text-muted py-4") 
                        | Chưa có sản phẩm nào trong hệ thống.