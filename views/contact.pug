extends layouts/default.pug
include mixins/box-head.pug

block main
    +box-head("Liên Hệ", "Để lại thông tin, chúng tôi sẽ hỗ trợ bạn")

    div.row
        div.col-md-6
            if successMessage
                div.alert.alert-success #{successMessage}
            if message
                div.alert.alert-info #{message}

            //- 1. method="POST" và route
            form.border.p-4.rounded.shadow-sm(action="/contact" method="POST")
                div.mb-3
                    label.form-label Họ và tên
                    input.form-control(type="text" name="fullName" placeholder="Nhập tên của bạn" required)

                div.mb-3
                    label.form-label Email
                    input.form-control(type="email" name="email" placeholder="name@example.com" required)

                div.mb-3
                    label.form-label Lời nhắn
                    textarea.form-control(name="message" rows="4" placeholder="Bạn cần hỗ trợ gì?" required)

                button.btn.btn-success.w-100(type="submit") Gửi liên hệ